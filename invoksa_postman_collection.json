                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "clients",
                                "1"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Client",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/clients/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
