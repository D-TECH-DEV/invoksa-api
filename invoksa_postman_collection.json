        {
            "name": "AI Generation",
            "item": [
                {
                    "name": "Generate Invoice from Text",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{jwt_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/ia/invoice?description=Facture de 500 euros pour la creation de logo&lang=fr",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
